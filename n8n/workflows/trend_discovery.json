{
  "id": "workflow-trend-discovery",
  "name": "Trend Discovery",
  "active": false,
  "settings": {
    "saveManualExecutions": true,
    "callerPolicy": "workflowsFromSameOwner"
  },
  "nodes": [
    {
      "id": "node-cron-6am",
      "name": "Daily 6 AM",
      "type": "n8n-nodes-base.cron",
      "typeVersion": 1,
      "position": [240, 300],
      "parameters": {
        "triggerTimes": {
          "item": [
            {
              "mode": "everyDay",
              "hour": 6,
              "minute": 0
            }
          ]
        }
      }
    },
    {
      "id": "node-trigger-discover",
      "name": "Trigger Discover Topics",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [460, 300],
      "parameters": {
        "method": "POST",
        "url": "http://backend:8000/api/v1/webhooks/n8n/schedule-trigger",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "X-Webhook-Secret",
              "value": "={{ $env.APP_SECRET_KEY }}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "{\n  \"action\": \"discover_topics\"\n}",
        "options": {
          "timeout": 30000
        }
      }
    },
    {
      "id": "node-check-discover-response",
      "name": "Check Response",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [680, 300],
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "cond-success",
              "leftValue": "={{ $json.success }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "equal"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      }
    },
    {
      "id": "node-log-success",
      "name": "Log Discovery Success",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3,
      "position": [900, 220],
      "parameters": {
        "mode": "manual",
        "duplicateItem": false,
        "assignments": {
          "assignments": [
            {
              "id": "assign-result",
              "name": "result",
              "value": "success",
              "type": "string"
            },
            {
              "id": "assign-message",
              "name": "message",
              "value": "={{ $json.message || 'Trending topics discovered and cached in Redis' }}",
              "type": "string"
            },
            {
              "id": "assign-task-id",
              "name": "task_id",
              "value": "={{ $json.task_id || '' }}",
              "type": "string"
            },
            {
              "id": "assign-ran-at",
              "name": "ran_at",
              "value": "={{ $now.toISO() }}",
              "type": "string"
            }
          ]
        },
        "options": {}
      }
    },
    {
      "id": "node-log-failure",
      "name": "Log Discovery Failure",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3,
      "position": [900, 400],
      "parameters": {
        "mode": "manual",
        "duplicateItem": false,
        "assignments": {
          "assignments": [
            {
              "id": "assign-result",
              "name": "result",
              "value": "failed",
              "type": "string"
            },
            {
              "id": "assign-error",
              "name": "error",
              "value": "={{ $json.error || $json.detail || 'Unknown error from schedule-trigger endpoint' }}",
              "type": "string"
            },
            {
              "id": "assign-ran-at",
              "name": "ran_at",
              "value": "={{ $now.toISO() }}",
              "type": "string"
            }
          ]
        },
        "options": {}
      }
    }
  ],
  "connections": {
    "Daily 6 AM": {
      "main": [
        [
          {
            "node": "Trigger Discover Topics",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Trigger Discover Topics": {
      "main": [
        [
          {
            "node": "Check Response",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Check Response": {
      "main": [
        [
          {
            "node": "Log Discovery Success",
            "type": "main",
            "index": 0
          }
        ],
        [
          {
            "node": "Log Discovery Failure",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  }
}
