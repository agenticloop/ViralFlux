# ── App ──────────────────────────────────────────────────────────────────────

# Application environment (development | staging | production)
APP_ENV=production

# Secret key used for signing sessions and internal tokens (min 64 chars)
APP_SECRET_KEY=change-me-64-chars-min-replace-with-a-secure-random-string-here

# Public-facing URL of this deployment (no trailing slash)
APP_URL=https://viralflux.example.com

# Next.js public env: base URL of the app (exposed to the browser)
NEXT_PUBLIC_APP_URL=https://viralflux.example.com

# Next.js public env: base URL of the API (exposed to the browser)
NEXT_PUBLIC_API_URL=https://viralflux.example.com/api

# Default timezone for the application and n8n scheduler (IANA format)
TIMEZONE=America/New_York


# ── PostgreSQL ────────────────────────────────────────────────────────────────

# Hostname of the PostgreSQL server (use service name inside Docker)
POSTGRES_HOST=postgres

# PostgreSQL port
POSTGRES_PORT=5432

# Primary application database name
POSTGRES_DB=viralflux

# PostgreSQL superuser / app user name
POSTGRES_USER=viralflux_user

# PostgreSQL password — use a strong random string in production
POSTGRES_PASSWORD=change-me-strong-db-password

# Full SQLAlchemy database URL (used by FastAPI / Alembic)
DATABASE_URL=postgresql+asyncpg://viralflux_user:change-me-strong-db-password@postgres:5432/viralflux


# ── Redis / Celery ────────────────────────────────────────────────────────────

# Redis connection URL (used by cache and Celery broker)
REDIS_URL=redis://redis:6379/0

# Celery broker URL — must point at Redis
CELERY_BROKER_URL=redis://redis:6379/0

# Celery result backend — must point at Redis
CELERY_RESULT_BACKEND=redis://redis:6379/1


# ── JWT Authentication ────────────────────────────────────────────────────────

# Secret key for signing JWT tokens (should differ from APP_SECRET_KEY)
JWT_SECRET_KEY=change-me-jwt-secret-key-replace-with-a-secure-random-string

# JWT signing algorithm
JWT_ALGORITHM=HS256

# Access token lifetime in minutes
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15

# Refresh token lifetime in days
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7


# ── SMTP / Email ──────────────────────────────────────────────────────────────

# SMTP server hostname
SMTP_HOST=smtp.example.com

# SMTP server port (587 for STARTTLS, 465 for SSL)
SMTP_PORT=587

# SMTP login username / email address
SMTP_USER=noreply@example.com

# SMTP login password
SMTP_PASSWORD=change-me-smtp-password

# Human-readable sender name shown in the From field
SMTP_FROM_NAME=ViralFlux

# Sender email address shown in the From field
SMTP_FROM_EMAIL=noreply@example.com


# ── Google AI / Gemini ────────────────────────────────────────────────────────

# Google AI Studio API key for Gemini models
GOOGLE_AI_API_KEY=AIzaSy-replace-with-your-google-ai-api-key

# Gemini model ID to use for content generation
GEMINI_MODEL=gemini-2.5-flash-lite


# ── OpenAI ────────────────────────────────────────────────────────────────────

# OpenAI API key
OPENAI_API_KEY=sk-replace-with-your-openai-api-key

# OpenAI model ID to use for completions / chat
OPENAI_MODEL=gpt-4o-mini


# ── Text-to-Speech ────────────────────────────────────────────────────────────

# ElevenLabs API key for high-quality AI voice synthesis
ELEVENLABS_API_KEY=replace-with-your-elevenlabs-api-key

# Google Text-to-Speech API key (fallback / alternative TTS)
GOOGLE_TTS_API_KEY=AIzaSy-replace-with-your-google-tts-api-key


# ── Stock Media APIs ──────────────────────────────────────────────────────────

# Pexels API key for royalty-free photos and videos
PEXELS_API_KEY=replace-with-your-pexels-api-key

# Pixabay API key for royalty-free images and videos
PIXABAY_API_KEY=replace-with-your-pixabay-api-key

# Unsplash Access Key for high-quality photos
UNSPLASH_ACCESS_KEY=replace-with-your-unsplash-access-key


# ── YouTube / Google OAuth ────────────────────────────────────────────────────

# Google OAuth 2.0 client ID (YouTube Data API v3)
YOUTUBE_CLIENT_ID=replace-with-your-youtube-oauth-client-id

# Google OAuth 2.0 client secret
YOUTUBE_CLIENT_SECRET=replace-with-your-youtube-oauth-client-secret

# Authorized redirect URI registered in Google Cloud Console
YOUTUBE_REDIRECT_URI=https://viralflux.example.com/api/auth/youtube/callback


# ── Reddit API ────────────────────────────────────────────────────────────────

# Reddit app client ID (for content scraping / trend detection)
REDDIT_CLIENT_ID=replace-with-your-reddit-client-id

# Reddit app client secret
REDDIT_CLIENT_SECRET=replace-with-your-reddit-client-secret

# User-Agent string sent with Reddit API requests
REDDIT_USER_AGENT=ViralFlux/1.0


# ── Stripe (Billing) ─────────────────────────────────────────────────────────

# Stripe secret key (server-side only — never expose to the browser)
STRIPE_SECRET_KEY=sk_live_replace-with-your-stripe-secret-key

# Stripe publishable key (safe to expose to the browser)
STRIPE_PUBLISHABLE_KEY=pk_live_replace-with-your-stripe-publishable-key

# Stripe webhook signing secret (validate incoming webhook events)
STRIPE_WEBHOOK_SECRET=whsec_replace-with-your-stripe-webhook-secret


# ── n8n Workflow Automation ───────────────────────────────────────────────────

# n8n admin username for basic-auth login
N8N_USER=admin

# n8n admin password — use a strong random string
N8N_PASSWORD=change-me-strong-n8n-password

# Hostname that n8n uses to construct webhook URLs
N8N_HOST=viralflux.example.com

# Full public webhook base URL (must be reachable from external services)
N8N_WEBHOOK_URL=https://viralflux.example.com/n8n/

# Dedicated PostgreSQL database for n8n workflow storage
N8N_DB_NAME=n8n

# Encryption key for n8n credentials at rest (32+ random chars)
N8N_ENCRYPTION_KEY=change-me-32-char-n8n-encryption-key


# ── Video Processing ──────────────────────────────────────────────────────────

# Path to the ffmpeg binary inside the container
FFMPEG_PATH=/usr/bin/ffmpeg

# Whisper model size for speech recognition (tiny | base | small | medium | large)
WHISPER_MODEL=base

# Maximum allowed video duration in seconds
MAX_VIDEO_DURATION_SEC=60

# Output video resolution (width x height) — portrait format for Shorts
VIDEO_RESOLUTION=1080x1920


# ── Storage ───────────────────────────────────────────────────────────────────

# Absolute path to the media directory inside the container
MEDIA_DIR=/app/media

# Absolute path to the static assets directory inside the container
ASSETS_DIR=/app/assets

# Maximum total media storage in gigabytes before cleanup triggers
MAX_STORAGE_GB=50


# ── Encryption ────────────────────────────────────────────────────────────────

# 32-byte hex key used for encrypting sensitive tokens at rest (e.g., OAuth tokens)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
ENCRYPTION_KEY=replace-with-64-hex-char-string-generated-via-secrets-token-hex-32
