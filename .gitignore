# ── Frontend Build Artifacts ──────────────────────────────────────────────────
frontend/.next/
frontend/out/
frontend/dist/
frontend/build/
frontend/node_modules/

# Re-include the frontend SOURCE lib — the generic `lib/` rule above (a Python
# build-artifact pattern) is unanchored and otherwise swallows this real source
# directory. Re-include the directory first, then its contents (git cannot
# re-include a file whose parent dir is excluded).
!frontend/src/lib/
!frontend/src/lib/**

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ── Media: Generated Content (large, transient) ───────────────────────────────
media/previews/*
media/final/*
media/temp/*
media/cache/*

# ── Video & Audio Files (everywhere except assets/) ──────────────────────────
*.mp4
*.mov
*.avi
*.mkv
*.webm
*.mp3
*.wav
*.m4a
*.aac
*.ogg
!assets/**/*.mp4
!assets/**/*.mp3
!assets/**/*.wav

# ── Images (generated / temp) ────────────────────────────────────────────────
media/**/*.jpg
media/**/*.jpeg
media/**/*.png
media/**/*.gif
media/**/*.webp

